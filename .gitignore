# ══════════════════════════════════════════════════════════════════════════════
# Rehnuma - AI-Powered Probability & Statistics Tutor
# Root-Level .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# Environment & Secrets (CRITICAL - Never commit API keys)
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ─────────────────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
ENV/
env/
.venv/

# Pytest
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ─────────────────────────────────────────────────────────────────────────────
# ChromaDB - Vector Database (Regenerate with: python Scripts/chromadb_setup.py)
# ─────────────────────────────────────────────────────────────────────────────
chroma_db/

# ─────────────────────────────────────────────────────────────────────────────
# Manim - Generated Media Files
# ─────────────────────────────────────────────────────────────────────────────
media/
*.mp4
*.mov
*.avi
*.gif

# ─────────────────────────────────────────────────────────────────────────────
# Node.js / Next.js (Frontend specific - also in Frontend/.gitignore)
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
.next/
out/
.vercel

# ─────────────────────────────────────────────────────────────────────────────
# IDE & Editor Settings
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.hintrc

# ─────────────────────────────────────────────────────────────────────────────
# Operating System Files
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────────────────────────────────────
# Logs & Debug
# ─────────────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─────────────────────────────────────────────────────────────────────────────
# TypeScript Build Info
# ─────────────────────────────────────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ─────────────────────────────────────────────────────────────────────────────
# Database Files
# ─────────────────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.pkl
*.pickle

# ─────────────────────────────────────────────────────────────────────────────
# Cache & Temporary Files
# ─────────────────────────────────────────────────────────────────────────────
.cache/
*.cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# ─────────────────────────────────────────────────────────────────────────────
# Miscellaneous
# ─────────────────────────────────────────────────────────────────────────────
*.pem
*.local
.env.local

# GitHub-specific (keep .github folder but ignore appmod cache)
.github/appmod/
